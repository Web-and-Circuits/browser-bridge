{
  "manifest_version": 3,
  "name": "Browser Bridge",
  "version": "0.1.0",
  "description": "File-mediated bridge that lets local agents inspect the active tab and run bounded JavaScript.",
  "permissions": ["activeTab", "scripting", "tabs", "storage", "nativeMessaging"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Browser Bridge",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
